model Attachment {
  id        String    @id @default(uuid())
  filename  String
  url       String
  mimeType  String
  size      Int
  taskId    String
  userId    String
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])

  @@index([taskId])
}