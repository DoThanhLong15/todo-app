{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "es2017",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictPropertyInitialization": false,
    "strict": true,
    "noImplicitAny": false,
    "moduleResolution": "node",
    "lib": ["esnext"],
    "paths": {
      "@/*": ["src/*"],
      "@common/*": ["src/common/*"],
      "@config/*": ["src/config/*"],
      "@modules/*": ["src/modules/*"],
      "@prisma/*": ["src/prisma/*"],
      "@generated-prisma/*": ["./generated/prisma/*"],
    }
  },
  "include": ["src/**/*", "test/**/*", "@generated", "src/modules/auth/utils"],
  "exclude": ["node_modules", "dist"]
}